    <!-- FAN -->
    <circle cx="30" cy="112" r="8" fill="none" stroke="rgba(0,229,255,0.15)" stroke-width="1"/>
    <circle cx="30" cy="112" r="3" fill="rgba(0,229,255,0.08)" stroke="rgba(0,229,255,0.3)" stroke-width="0.8"/>
    <line x1="30" y1="104" x2="30" y2="108" stroke="rgba(0,229,255,0.25)" stroke-width="1.2"/>
    <line x1="30" y1="116" x2="30" y2="120" stroke="rgba(0,229,255,0.25)" stroke-width="1.2"/>
    <line x1="22" y1="112" x2="26" y2="112" stroke="rgba(0,229,255,0.25)" stroke-width="1.2"/>
    <line x1="34" y1="112" x2="38" y2="112" stroke="rgba(0,229,255,0.25)" stroke-width="1.2"/>
    <text x="30" y="123" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="5" fill="rgba(0,229,255,0.25)">FAN</text>
  </svg>
</div>

<!-- 主内容 -->
<main class="main">
  <!-- 欢迎页 -->
  <div id="welcomePage">
    <!-- 品牌区 -->
    <div class="welcome-brand">
      <div class="wb-icon">
        <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <defs>
            <linearGradient id="myAIwbLG" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#7dffff"/>
              <stop offset="45%" stop-color="#00c8ea"/>
              <stop offset="100%" stop-color="#a78bfa"/>
            </linearGradient>
            <linearGradient id="myAIwbBG" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#152238"/>
              <stop offset="1" stop-color="#060b14"/>
            </linearGradient>
            <linearGradient id="myAIwbGL" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="#00f5ff" stop-opacity="0"/>
              <stop offset="50%" stop-color="#00f5ff" stop-opacity="0.35"/>
              <stop offset="100%" stop-color="#00f5ff" stop-opacity="0"/>
            </linearGradient>
          </defs>
          <rect x="3" y="5" width="34" height="23" rx="5.5" fill="url(#myAIwbBG)" stroke="url(#myAIwbLG)" stroke-width="1.45"/>
          <rect x="7" y="9" width="26" height="13" rx="2.2" fill="#030810" stroke="rgba(0,229,255,0.14)" stroke-width="0.6"/>
          <rect x="9" y="11" width="10" height="2.4" rx="1.2" fill="url(#myAIwbLG)"/>
          <rect x="9" y="15.4" width="17" height="2.4" rx="1.2" fill="url(#myAIwbLG)" opacity="0.5"/>
          <rect x="9" y="19.8" width="12" height="1.7" rx="0.85" fill="url(#myAIwbLG)" opacity="0.32"/>
          <rect x="7" y="9" width="26" height="6" rx="2.2" fill="url(#myAIwbGL)"/>
          <path d="M15 28.5h10l-1.4 4.8h-7.2z" fill="url(#myAIwbLG)"/>
          <ellipse cx="20" cy="34.2" rx="9" ry="1.4" fill="#00e5ff" opacity="0.25"/>
        </svg>
      </div>
      <div class="wb-text">
        <span class="wb-name">联信装机</span>
        <span class="wb-sub">PC Builder <span class="pro-badge">PRO</span></span>
      </div>
    </div>

    <h2>你好！我是你的装机顾问</h2>
    <p>我可以帮你推荐电脑配置、解答硬件兼容性、评估性价比，<br>以及任何装机相关的问题。</p>
    <div class="quick-prompts">
      <button class="qp-btn" data-msg="🎮 游戏主机推荐">🎮 游戏主机推荐</button>
      <button class="qp-btn" data-msg="⚔️ 配置兼容性检查">⚔️ 配置兼容性检查</button>
      <button class="qp-btn" data-msg="💻 CPU 选择建议">💻 CPU 选择建议</button>
      <button class="qp-btn" data-msg="🔍 显卡对比分析">🔍 显卡对比分析</button>
      <button class="qp-btn" data-msg="📚 装机步骤与避坑">📚 装机步骤与避坑</button>
      <button class="qp-btn" data-msg="⚡ 电源与散热参考">⚡ 电源与散热参考</button>
      <button class="qp-btn" data-msg="💰 预算分配指南">💰 预算分配指南</button>
    </div>
  </div>

  <!-- 聊天区 -->
  <div id="chatArea"></div>

  <!-- 音色选择栏 -->
  <div class="voice-bar" id="voiceBar">
    <span class="voice-label">音色</span>
    <button class="voice-btn" id="voiceName">晓晓 (女声)</button>
    <svg class="voice-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
    <div class="voice-sep"></div>
    <label class="auto-tts-label" title="发送后自动朗读 AI 回复">
      <span>自动朗读</span>
      <input type="checkbox" id="autoTtsToggle">
      <span class="toggle-track"><span class="toggle-thumb"></span></span>
    </label>
  </div>

  <!-- 输入栏 -->
  <div class="input-wrap">
    <div class="input-bar">
      <textarea id="msgInput" class="msg-input" placeholder="向 AI 发送消息..." autocomplete="off" rows="1"></textarea>
      <button type="button" class="btn-mic" id="btnMic" title="语音输入">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2a3 3 0 0 1 3 3v7a3 3 0 0 1-6 0V5a3 3 0 0 1 3-3z"/>
          <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
          <line x1="12" y1="19" x2="12" y2="22"/>
          <line x1="8" y1="22" x2="16" y2="22"/>
        </svg>
      </button>
      <button type="button" class="btn-send" id="btnSend">发送</button>
    </div>
  </div>
</main>

<script>
(function () {
  const TAU = Math.PI * 2;

  // ── 头像动画 ─────────────────────────────────────────────
  function drawSphere(cv) {
    const ctx = cv.getContext('2d');
    const w = cv.width, h = cv.height, cx = w / 2, cy = h / 2;
    const t = Date.now() * 0.002;
    ctx.clearRect(0, 0, w, h);

    // 主体球
    const grd = ctx.createRadialGradient(cx - 4, cy - 6, 2, cx, cy, 18);
    grd.addColorStop(0,   '#b0f4ff');
    grd.addColorStop(0.4, '#00d4f0');
    grd.addColorStop(1,   '#060c20');
    ctx.fillStyle = grd;
    ctx.beginPath();
    ctx.arc(cx, cy, 18, 0, TAU);
    ctx.fill();

    // 紫色光点轨道
    for (let i = 0; i < 14; i++) {
      const a = (i / 14) * TAU + t * 0.7;
      const r = 12 + Math.sin(i * 1.6 + t) * 2;
      const alpha = 0.2 + (i % 4) * 0.1;
      ctx.fillStyle = `rgba(167, 139, 250, ${alpha})`;
      ctx.beginPath();
      ctx.arc(cx + Math.cos(a) * r * 0.9, cy + Math.sin(a) * r * 0.75, 1.1, 0, TAU);
      ctx.fill();
    }

    // 青色高光
    for (let i = 0; i < 8; i++) {
      const a = (i / 8) * TAU - t * 0.4;
      const r = 15 + Math.sin(i * 2.1 + t) * 2;
      ctx.fillStyle = `rgba(0, 229, 255, 0.25)`;
      ctx.beginPath();
      ctx.arc(cx + Math.cos(a) * r * 0.85, cy + Math.sin(a) * r * 0.7, 0.9, 0, TAU);
      ctx.fill();
    }
  }

  function loopSpheres() {
    drawSphere(document.getElementById('sphereCv'));
    drawSphere(document.getElementById('sphereCv2'));
    requestAnimationFrame(loopSpheres);
  }

  // ── 聊天逻辑 ──────────────────────────────────────────────
  const chatArea = document.getElementById('chatArea');
  const msgInput = document.getElementById('msgInput');
  const btnSend  = document.getElementById('btnSend');
  let sessionMsgs = [];

  function scrollChat() {
    chatArea.scrollTop = chatArea.scrollHeight;
  }

  function escapeHtml(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function formatTime() {
    const now = new Date();
    return [now.getHours(), now.getMinutes()].map(v => String(v).padStart(2,'0')).join(':');
  }

  function addBubble(role, text, timeStr) {
    const logoSvg = `<svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id="lxAI" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#7dffff"/>
          <stop offset="45%" stop-color="#00c8ea"/>
          <stop offset="100%" stop-color="#a78bfa"/>
        </linearGradient>
        <linearGradient id="lxAI2" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#152238"/>
          <stop offset="1" stop-color="#060b14"/>
        </linearGradient>
        <linearGradient id="lxAI3" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="#00f5ff" stop-opacity="0"/>
          <stop offset="50%" stop-color="#00f5ff" stop-opacity="0.35"/>
          <stop offset="100%" stop-color="#00f5ff" stop-opacity="0"/>
        </linearGradient>
      </defs>
      <rect x="3" y="5" width="34" height="23" rx="5.5" fill="url(#lxAI2)" stroke="url(#lxAI)" stroke-width="1.45"/>
      <rect x="7" y="9" width="26" height="13" rx="2.2" fill="#030810" stroke="rgba(0,229,255,0.14)" stroke-width="0.6"/>
      <rect x="9" y="11" width="10" height="2.4" rx="1.2" fill="url(#lxAI)"/>
      <rect x="9" y="15.4" width="17" height="2.4" rx="1.2" fill="url(#lxAI)" opacity="0.5"/>
      <rect x="9" y="19.8" width="12" height="1.7" rx="0.85" fill="url(#lxAI)" opacity="0.32"/>
      <rect x="7" y="9" width="26" height="6" rx="2.2" fill="url(#lxAI3)"/>
      <path d="M15 28.5h10l-1.4 4.8h-7.2z" fill="url(#lxAI)"/>
      <ellipse cx="20" cy="34.2" rx="9" ry="1.4" fill="#00e5ff" opacity="0.25"/>
    </svg>`;

    const row = document.createElement('div');
    row.className = `msg-row ${role}`;
    if (role === 'ai') {
      row.innerHTML = `<div class="msg-bubble"><div class="ai-logo">${logoSvg}</div><div class="ai-text">${escapeHtml(text)}<button class="tts-btn" title="朗读"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg></button></div></div><div class="msg-time">${timeStr}</div>`;
    } else {
      row.innerHTML = `<div class="msg-bubble">${escapeHtml(text)}</div><div class="msg-time">${timeStr}</div>`;
    }
    chatArea.appendChild(row);
    scrollChat();
    return row;
  }

  function showTyping() {
    const wrap = document.createElement('div');
    wrap.className = 'msg-row ai';
    wrap.id = 'typingEl';
    wrap.innerHTML = `<div class="typing-wrap"><span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span></div>`;
    chatArea.appendChild(wrap);
    scrollChat();
  }

  function removeTyping() {
    document.getElementById('typingEl')?.remove();
  }

  function setLoading(on) {
    btnSend.disabled = on;
    msgInput.disabled = on;
  }

  async function sendMessage() {
    const text = msgInput.value.trim();
    if (!text || btnSend.disabled) return;
    // 保存语音输入标记，sendMessage 内部不重置（等 AI 回复到达时用）
    const fromVoice = lastMsgByVoice;
    if (!fromVoice) lastMsgByVoice = false;

    // 隐藏欢迎页
    const wp = document.getElementById('welcomePage');
    if (wp) wp.style.display = 'none';

    addBubble('user', text, formatTime());
    sessionMsgs.push({ role: 'user', content: text });
    msgInput.value = '';
    setLoading(true);

    showTyping();

    try {
      const useStream = false; // 后端返回普通JSON，暂不支持SSE流式

      if (useStream) {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: sessionMsgs, stream: true })
        });

        removeTyping();

        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          addBubble('ai', `❌ 请求失败：${err.reply || err.error || res.status}`, formatTime());
          setLoading(false);
          return;
        }

        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let full = '';

        const aiRow = addBubble('ai', '', formatTime());
        const bubble = aiRow.querySelector('.msg-bubble');
        const ttsBtn = aiRow.querySelector('.tts-btn');

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          const chunk = decoder.decode(value, { stream: true });
          for (const line of chunk.split('\n')) {
            if (!line.startsWith('data: ')) continue;
            const data = line.slice(6).trim();
            if (data === '[DONE]') continue;
            try {
              const parsed = JSON.parse(data);
              const content = parsed.choices?.[0]?.delta?.content || '';
              if (content) {
                full += content;
                // 流式过程中不插入 ttsBtn，避免按钮在中间气泡间被移动导致音频错乱
                const txt = document.createElement('div');
                txt.className = 'ai-text';
                txt.innerHTML = escapeHtml(full);
                bubble.innerHTML = `<div class="ai-logo">${logoSvg}</div>`;
                bubble.appendChild(txt);
                scrollChat();
              }
            } catch {}
          }
        }

        sessionMsgs.push({ role: 'assistant', content: full });

        // 流式完成后追加 TTS 按钮到气泡，并触发自动朗读（语音输入场景）
        if (ttsBtn) {
          bubble.appendChild(ttsBtn);
          if (lastMsgByVoice || document.getElementById('autoTtsToggle')?.checked) {
            setTimeout(autoSpeakLastAi, 100);
          }
          // 只在语音输入路径重置，避免打字的残留
          if (lastMsgByVoice) lastMsgByVoice = false;
        }

      } else {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: sessionMsgs, stream: false })
        });

        removeTyping();

        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          addBubble('ai', `❌ 请求失败：${err.reply || err.error || res.status}`, formatTime());
          setLoading(false);
          return;
        }

        const data = await res.json();
        const reply = data.reply || 'AI未返回有效内容';
        const aiRow = addBubble('ai', reply, formatTime());
        sessionMsgs.push({ role: 'assistant', content: reply });
        if (lastMsgByVoice || document.getElementById('autoTtsToggle')?.checked) {
          const ttsBtn = aiRow.querySelector('.tts-btn');
          if (ttsBtn) {
            setTimeout(() => autoSpeakLastAi(), 100);
          }
          lastMsgByVoice = false;
        }
      }

      document.getElementById('connStatus').textContent = '已连接';

    } catch (e) {
      removeTyping();
      addBubble('ai', `❌ 网络错误：${e.message}`, formatTime());
      document.getElementById('connStatus').textContent = '离线';
    }

    setLoading(false);
  }

  btnSend.addEventListener('click', sendMessage);
  msgInput.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  // ── 语音输入 ──────────────────────────────────────────────
  const btnMic = document.getElementById('btnMic');
  let recognition = null;
  let isRecording = false;

  function toggleVoice() {
    if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
      alert('当前浏览器不支持语音识别，建议使用 Chrome。');
      return;
    }
    if (isRecording) {
      stopVoice();
      return;
    }
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    recognition = new SR();
    recognition.lang = 'zh-CN';
    recognition.continuous = true;
    recognition.interimResults = true;

    recognition.onstart = () => {
      isRecording = true;
      btnMic.classList.add('recording');
    };
    recognition.onresult = (e) => {
      let transcript = '';
      for (let i = e.resultIndex; i < e.results.length; i++) {
        transcript += e.results[i][0].transcript;
      }
      if (transcript) {
        msgInput.value = transcript;
        msgInput.focus();
        lastMsgByVoice = true;
      }
    };
    recognition.onerror = (e) => {
      console.error('语音识别错误:', e.error);
      stopVoice();
    };
    recognition.onend = () => {
      stopVoice();
    };
    recognition.start();
  }

  function stopVoice() {
    if (recognition) {
      recognition.stop();
      recognition = null;
    }
    isRecording = false;
    btnMic.classList.remove('recording');
  }

  let lastMsgByVoice = false;

  btnMic.addEventListener('click', toggleVoice);

  // ── 语音输入后自动朗读 ────────────────────────────────
  function autoSpeakLastAi() {
    const rows = chatArea.querySelectorAll('.msg-row.ai');
    if (!rows.length) return;
    const lastRow = rows[rows.length - 1];
    const btn = lastRow.querySelector('.tts-btn');
    if (!btn) return;
    const text = (lastRow.querySelector('.ai-text')?.innerText || '').trim();
    if (!text) return;
    speakText(text, btn);
    lastMsgByVoice = false; // 重置标志
  }

  // ── TTS 朗读 ──────────────────────────────────────────────
  const VOICES = [
    { name: '晓晓 (女声)',        voice: 'zh-CN-XiaoxiaoNeural' },
    { name: '晓伊 (女声)',        voice: 'zh-CN-XiaoyiNeural'   },
    { name: '云健 (男声)',        voice: 'zh-CN-YunjianNeural'   },
    { name: '云希 (男声)',        voice: 'zh-CN-YunxiNeural'     },
    { name: '云夏 (男声)',        voice: 'zh-CN-YunxiaNeural'    },
    { name: '云扬 (男声)',        voice: 'zh-CN-YunyangNeural'   },
    { name: '小北 (东北女声)',    voice: 'zh-CN-liaoning-XiaobeiNeural' },
    { name: '小妮 (陕西女声)',    voice: 'zh-CN-shaanxi-XiaoniNeural' },
    { name: '希tera (香港女声)', voice: 'zh-HK-HiuGaaiNeural'   },
    { name: '惜 ter (香港女声)', voice: 'zh-HK-HiuMaanNeural'   },
    { name: '雲龍 (香港男声)',    voice: 'zh-HK-WanLungNeural'   },
    { name: '小喬 (台湾女声)',    voice: 'zh-TW-HsiaoChenNeural' },
  ];
  let currentVoiceIdx = 0;
  let currentAudio = null;

  function stopAllTts() {
    if (currentAudio) { currentAudio.pause(); currentAudio.currentTime = 0; currentAudio = null; }
    document.querySelectorAll('.tts-btn.playing').forEach(b => b.classList.remove('playing'));
  }

  function stripTtsText(raw) {
    return raw
      .replace(/\p{Emoji}/gu, '')         // 所有 emoji 图标
      .replace(/\*\*(.+?)\*\*/g, '$1')   // **bold** → bold
      .replace(/#{1,6}\s?/g, '')         // # heading markers
      .replace(/\*(.+?)\*/g, '$1')        // *italic* → italic
      .replace(/`(.+?)`/g, '$1')         // `code` → code
      .replace(/~~(.+?)~~/g, '$1')       // ~~strike~~ → strike
      .replace(/-{3,}/g, '')             // --- dividers
      .replace(/[ \t]+$/gm, '')           // trailing spaces
      .replace(/\n{3,}/g, '\n\n')        // excessive newlines
      .trim();
  }

  async function speakText(text, btn) {
    stopAllTts();
    btn.classList.add('playing');
    try {
      const res = await fetch('/api/tts', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: stripTtsText(text), voice: VOICES[currentVoiceIdx].voice }),
      });
      if (!res.ok) throw new Error((await res.json()).error || res.status);
      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      const audio = new Audio(url);
      currentAudio = audio;
      audio.onended = () => { btn.classList.remove('playing'); URL.revokeObjectURL(url); currentAudio = null; };
      audio.onerror = () => { btn.classList.remove('playing'); URL.revokeObjectURL(url); currentAudio = null; };
      audio.play();
    } catch (e) {
      btn.classList.remove('playing');
      console.error('[TTS] error:', e.message);
    }
  }

  // 更新音色按钮文字
  function updateVoiceBtn() {
    const v = VOICES[currentVoiceIdx];
    const vb = document.getElementById('voiceName');
    if (vb) vb.textContent = v.name;
  }

  // 双击 TTS 按钮切换音色（不再自动朗读）
  chatArea.addEventListener('dblclick', e => {
    const btn = e.target.closest('.tts-btn');
    if (!btn) return;
    stopAllTts();
    currentVoiceIdx = (currentVoiceIdx + 1) % VOICES.length;
    updateVoiceBtn();
  });

  // 单击 TTS 按钮播放
  chatArea.addEventListener('click', e => {
    const btn = e.target.closest('.tts-btn');
    if (!btn) return;
    const row = btn.closest('.msg-row');
    const text = row ? (row.querySelector('.ai-text')?.innerText || '').trim() : '';
    if (!text) return;
    if (btn.classList.contains('playing')) {
      stopAllTts();
      return;
    }
    speakText(text, btn);
  });

  // 单击音色栏切换音色
  document.addEventListener('click', e => {
    const vb = e.target.closest('.voice-bar');
    if (!vb) return;
    stopAllTts();
    currentVoiceIdx = (currentVoiceIdx + 1) % VOICES.length;
    updateVoiceBtn();
  });

  // ── 快速入口 ──────────────────────────────────────────────
  document.querySelectorAll('.qp-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const msg = btn.getAttribute('data-msg');
      msgInput.value = msg;
      sendMessage();
    });
  });

  // ── 离开提示 ──────────────────────────────────────────────
  window.addEventListener('beforeunload', e => {
    if (sessionMsgs.length > 0) {
      e.preventDefault();
      e.returnValue = '';
    }
  });

  // 头像动画已移除（顶栏改用 SVG）
  // loopSpheres();

})();
</script>
